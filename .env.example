# Region configuration
REGION_ID=us # us, eu, or apac
PORT=3001

# Database configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=incident_db
DB_HOST=db-us
DB_PORT=5432

# Peer replication URLs (comma separated)
PEER_URLS=http://region-eu:3002,http://region-apac:3003

# Replication interval in milliseconds
REPLICATION_INTERVAL=5000
